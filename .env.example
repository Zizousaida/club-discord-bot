DISCORD_TOKEN=

# Optional: restrict slash command sync to a single guild (recommended for dev)
GUILD_ID=

# Permission roles (role names in your Discord server)
HR_ROLE_NAME=HR
STAFF_ROLE_NAME=Staff

# Optional: channel where moderation actions will be logged
LOG_CHANNEL_ID=

# SQLite database file path (relative or absolute)
DATABASE_PATH=club_bot.db

# Command response visibility:
# true  -> replies are visible to everyone in channel
# false -> replies are private (ephemeral)
COMMAND_RESPONSES_PUBLIC=true

